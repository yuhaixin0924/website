---
import PageLayout from '~/layouts/PageLayout.astro';
import Grid from '~/components/blog/Grid.astro';
import { fetchPosts } from '~/utils/blog';

const posts = await fetchPosts();

const metadata = {
	title: 'Blog',
	description: '记录我自己的文章、笔记和算法整理。',
};
---

<PageLayout metadata={metadata}>
	<section class="relative overflow-hidden py-16 sm:py-20 lg:py-24">
		<div class="absolute inset-0 -z-10 bg-gradient-to-b from-blue-50 via-white to-white dark:from-slate-950 dark:via-slate-900 dark:to-slate-950"></div>
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl mb-12 lg:mb-16">
				<p class="text-sm font-semibold uppercase tracking-[0.3em] text-primary">Blog</p>
				<h1 class="mt-4 text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
					我的文章与笔记
				</h1>
				<p class="mt-6 text-lg leading-8 text-muted dark:text-slate-300">
					这里现在只保留你自己的文章。后续新增内容会继续沿用同样的卡片和导航样式。
				</p>
			</div>

			{posts.length > 0 ? <Grid posts={posts} /> : <p class="text-muted dark:text-slate-300">暂无文章。</p>}
		</div>
	</section>
</PageLayout>
